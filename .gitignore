# Build results
bin/
obj/

# Visual Studio temporary files, build results, and
# files generated by popular Visual Studio add-ons.
.vs/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Mono Auto Generated Files
mono_crash.*

# OS generated files
.DS_Store
Thumbs.db

# NuGet packages
*.nupkg
