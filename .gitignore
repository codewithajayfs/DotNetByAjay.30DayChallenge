**/packages/*

# Visual Studio Code workspace settings
.vscode/

# Rider
.idea/

# .NET Core publish folder
publish/

# Visual Studio profiler
*.psess
*.vsp
*.vspx

# Visual Studio cache files
*.cache

# Rider project files
*.sln.iml

# Entity Framework files
*.EntityFrameworkCore.*

# User-specific files generated by Visual Studio
*.userprefs

# JetBrains Rider local history
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/dictionaries
.idea/**/shelf
